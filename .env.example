APP_NAME=Hovera
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Warsaw
APP_URL=https://app.hovera.app

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────
# Database — three connections
#
#   central       core DB (tenants, users, plans, billing, audit log)
#   tenant        per-stable DB, reconfigured at runtime per request
#   provisioner   used only to CREATE/DROP tenant databases & users
# ─────────────────────────────────────────────────────────────────────
DB_CONNECTION=central

# Central DB (always pointing to hovera_core)
DB_CENTRAL_DRIVER=mysql
DB_CENTRAL_HOST=127.0.0.1
DB_CENTRAL_PORT=3306
DB_CENTRAL_DATABASE=hovera_core
DB_CENTRAL_USERNAME=hovera_core
DB_CENTRAL_PASSWORD=

# Tenant DB host (database/user resolved per request)
DB_TENANT_HOST=127.0.0.1
DB_TENANT_PORT=3306

# Provisioner — needs CREATE/DROP DATABASE, CREATE USER, GRANT OPTION
DB_PROVISIONER_HOST=127.0.0.1
DB_PROVISIONER_PORT=3306
DB_PROVISIONER_USERNAME=hovera_provisioner
DB_PROVISIONER_PASSWORD=

# Naming convention for new tenant databases & users.
# {slug} is replaced with the tenant slug (e.g. "stajnia-wisla").
HOVERA_TENANT_DB_PREFIX=hovera_t_
HOVERA_TENANT_USER_PREFIX=hovera_t_
HOVERA_TENANT_DB_HOST=127.0.0.1

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=hovera

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@hovera.app"
MAIL_FROM_NAME="${APP_NAME}"

# Master admin
HOVERA_ADMIN_PATH=admin
HOVERA_ADMIN_REQUIRE_2FA=true

# Public micro-site path prefix (e.g. https://app.hovera.app/s/{slug})
HOVERA_PUBLIC_SITE_PREFIX=s

VITE_APP_NAME="${APP_NAME}"
