APP_NAME=Hovera
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Warsaw
APP_URL=https://app.hovera.app

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────
# Database — three connections
#
#   central       core DB (tenants, users, plans, billing, audit log)
#   tenant        per-stable DB, reconfigured at runtime per request
#   provisioner   used only to CREATE/DROP tenant databases & users
# ─────────────────────────────────────────────────────────────────────
DB_CONNECTION=central

# Central DB (always pointing to hovera_core)
DB_CENTRAL_DRIVER=mysql
DB_CENTRAL_HOST=127.0.0.1
DB_CENTRAL_PORT=3306
DB_CENTRAL_DATABASE=hovera_core
DB_CENTRAL_USERNAME=hovera_core
DB_CENTRAL_PASSWORD=

# Tenant DB host (database/user resolved per request)
DB_TENANT_HOST=127.0.0.1
DB_TENANT_PORT=3306

# Provisioner — needs CREATE/DROP DATABASE, CREATE USER, GRANT OPTION
DB_PROVISIONER_HOST=127.0.0.1
DB_PROVISIONER_PORT=3306
DB_PROVISIONER_USERNAME=hovera_provisioner
DB_PROVISIONER_PASSWORD=

# Naming convention for new tenant databases & users.
# {slug} is replaced with the tenant slug (e.g. "stajnia-wisla").
HOVERA_TENANT_DB_PREFIX=hovera_t_
HOVERA_TENANT_USER_PREFIX=hovera_t_
HOVERA_TENANT_DB_HOST=127.0.0.1

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=hovera

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────
# Mail
#
# Default driver `log` writes outgoing mails to storage/logs — fine for
# development (you can read invitation links in the log file).
#
# For production, pick one:
#
#   1. SMTP (Postmark / Mailgun / SES SMTP / your own server):
#        MAIL_MAILER=smtp
#        MAIL_HOST=smtp.postmarkapp.com
#        MAIL_PORT=587
#        MAIL_USERNAME=...
#        MAIL_PASSWORD=...
#        MAIL_ENCRYPTION=tls
#
#   2. Resend (recommended for new accounts; one driver, simple API):
#        composer require resend/resend-laravel
#        MAIL_MAILER=resend
#        RESEND_KEY=re_***
#
# ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@hovera.app"
MAIL_FROM_NAME="${APP_NAME}"

# Master admin
HOVERA_ADMIN_PATH=admin
HOVERA_ADMIN_REQUIRE_2FA=true

# Public micro-site path prefix (e.g. https://app.hovera.app/s/{slug})
HOVERA_PUBLIC_SITE_PREFIX=s

# ─────────────────────────────────────────────────────────────────────
# Performance monitoring (opt-in; see docs/PERFORMANCE.md)
# ─────────────────────────────────────────────────────────────────────
# Log every query slower than N ms. Set to 0 / unset to disable.
# Use during prod debugging — log spam if left on long-term.
HOVERA_SLOW_QUERY_LOG_MS=0
# Throw on lazy-loaded relations (catches N+1 in dev/CI).
# Do NOT enable in production — user gets 500 instead of slower page.
HOVERA_PREVENT_LAZY_LOADING=false

# ─────────────────────────────────────────────────────────────────────
# Todoist — in-app bug / feedback reporter
#
# Used by App\Services\Integrations\TodoistClient. Each report submitted
# from the topbar "?"/"bug" icon creates a task in the Hovera project.
# Token: Todoist → Settings → Integrations → Developer → API token.
# Project id is the Hovera project id from the URL (after /project/).
# ─────────────────────────────────────────────────────────────────────
TODOIST_API_TOKEN=
TODOIST_HOVERA_PROJECT_ID=6gcqjRCCQwVPWVXg

# ─────────────────────────────────────────────────────────────────────
# Stripe — central hovera SaaS billing (subscriptions + Customer Portal)
#
# These are NOT the per-tenant payment provider keys (those live in
# tenants.settings.payment.* encrypted via Crypt). This is hovera's own
# billing — each stable pays for hovera itself.
#
# After setting STRIPE_KEY/STRIPE_SECRET, register a webhook in the
# Stripe Dashboard pointing at:
#     https://app.hovera.app/webhooks/stripe
# and paste the signing secret into STRIPE_WEBHOOK_SECRET.
# ─────────────────────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Przelewy24 — central SaaS billing (one-time "Opłać fakturę" link)
#
# Komplementarne do Stripe (recurring) — gdy stajnia ma proformę albo
# jednorazową opłatę, generujemy link P24 zamiast Checkout. Webhook
# rejestrujemy w panelu P24 pointing at:
#     https://app.hovera.app/webhooks/przelewy24
#
# P24_ENV=sandbox uzywa https://sandbox.przelewy24.pl, production →
# https://secure.przelewy24.pl. NIE myl z per-tenant P24 (per-stable
# config siedzi w tenants.settings.payments.p24).
# ─────────────────────────────────────────────────────────────────────
P24_MERCHANT_ID=
P24_POS_ID=
P24_API_KEY=
P24_CRC=
P24_ENV=sandbox

# ─────────────────────────────────────────────────────────────────────
# KSeF — central (hovera as VAT taxpayer)
#
# Hovera musi wystawiać FV przez KSeF od 2026-02-01 (mandatoryjne dla
# B2B). Cert + hasło konfigurowane w /admin/ksef-settings (zapisane
# encrypted w central.system_settings). Tutaj tylko domyślny env.
#
# KSEF_CENTRAL_ENV: test | demo | production
# ─────────────────────────────────────────────────────────────────────
KSEF_CENTRAL_ENV=test
KSEF_CENTRAL_NIP=

# ─────────────────────────────────────────────────────────────────────
# Transport module — routing providers
#
# Klucze API dla zewnętrznych dostawców routingu. Per-tenant override
# trzymamy w `transport_settings.routing_provider.api_key`. Środowiskowe
# klucze służą jako fallback gdy tenant nie podał własnego (Solo plan
# domyślnie korzysta z ORS w shared mode).
#
# Patrz docs/TRANSPORT.md §7.
# ─────────────────────────────────────────────────────────────────────
TRANSPORT_ORS_KEY=
TRANSPORT_MAPBOX_TOKEN=
TRANSPORT_GOOGLE_ROUTES_KEY=
TRANSPORT_ROUTE_CACHE_TTL_DAYS=30

# Transport module — dedykowany SMTP do powiadomień (oferty do klientów,
# dispatcher do kierowców). Patrz docs/TRANSPORT.md §6. Osobny, by separacja
# reputacji domeny i własny From-address per klient (lub własna domena
# klienta w przyszłości).
TRANSPORT_MAIL_DRIVER=smtp
TRANSPORT_MAIL_HOST=
TRANSPORT_MAIL_PORT=587
TRANSPORT_MAIL_USERNAME=
TRANSPORT_MAIL_PASSWORD=
TRANSPORT_MAIL_ENCRYPTION=tls
TRANSPORT_MAIL_FROM_ADDRESS=transport@hovera.app
TRANSPORT_MAIL_FROM_NAME="Hovera Transport"

VITE_APP_NAME="${APP_NAME}"
